{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "types": ["chrome"]
  },
  "include": ["browser-extension/**/*.js"],
  "exclude": ["browser-extension/tests/**"]
}
